{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@zemen/core": ["../../packages/core/src/index.ts"],
      "@zemen/core/*": ["../../packages/core/src/*"],
      "@zemen/react": ["../../packages/react/src/index.ts"],
      "@zemen/react/*": ["../../packages/react/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "incremental": true,
    "esModuleInterop": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
